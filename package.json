{
  "name": "placeholder-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "AI-Powered UX Auditing Chrome Extension",
  "scripts": {
    "dev": "turbo run dev",
    "dev:extension": "turbo run dev --filter=@placeholder/extension",
    "dev:api": "turbo run dev --filter=@placeholder/api",
    "build": "turbo run build",
    "build:extension": "turbo run build --filter=@placeholder/extension",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
